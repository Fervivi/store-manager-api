# FullStack1 Duoc 2026
# Project orchestrator Makefile v0.1

API_REPO_URLS := \
	https://github.com/polirritmico/auth-api \
	https://github.com/lironscallealta/users-api \
	https://github.com/polirritmico/sales-api \
	https://github.com/Fervivi/invoice-api \
	https://github.com/polirritmico/carts-api \
	https://github.com/Fervivi/product-api \
	https://github.com/polirritmico/appointments-api \
	https://github.com/lironscallealta/pets-api \
	https://github.com/lironscallealta/vets-api \
	https://github.com/Fervivi/store-manager-api \
	https://github.com/lironscallealta/accounting-manager-api \
	https://github.com/polirritmico/vet-manager-api

INFRA_REPO_URLS := \
    https://github.com/polirritmico/api-gateway \
    https://github.com/polirritmico/eureka-server

ALL_REPO_URLS := $(API_REPO_URLS) $(INFRA_REPO_URLS)

SERVICES := $(notdir $(API_REPO_URLS))

DB_INIT_SCRIPT := init.sql
DB_INIT_VOL := mysql_init_volume
DB_USER ?= user
DB_PASSWORD ?= password
DOCKER_COMPOSE := docker compose --env-file /dev/null

.PHONY: help setup build up start stop run clean clone-all db-init

help:
	@echo "Available targets:"
	@echo "  run       : One-shot command to clone, generate scripts, build, and run in foreground"
	@echo "  detached  : Runs the containers detached in the background"
	@echo "  stop      : Stops active containers without wiping data"
	@echo "  clean     : Teardown. Stops containers, wipes volumes, and init scripts"
	@echo "  clean-full: Deep teardown. Also wipes cloned repositories"
	@echo "  setup     : Prepares the workspace (clones repos and builds init.sql)"
	@echo "  build     : Compiles docker images for all services (runs setup automatically)"
	@echo "  clone     : Clones all required service repositories"
	@echo "  db-init   : Generates database initialization script"
	@echo "  help      : Show this list"

setup: clone db-init

build: setup
	$(DOCKER_COMPOSE) build

detached:
	$(DOCKER_COMPOSE) up -d

stop:
	$(DOCKER_COMPOSE) down

run: setup
	$(DOCKER_COMPOSE) up --build

clone:
	@for url in $(ALL_REPO_URLS); do \
		dir=$$(basename $$url); \
		if [ ! -d "$$dir" ]; then \
			git clone $$url $$dir; \
		fi; \
	done

db-init:
	@echo "Generating database init script..."
	@echo "-- Auto-generated by Makefile" > $(DB_INIT_SCRIPT)
	@echo "CREATE USER IF NOT EXISTS '$(DB_USER)'@'%' IDENTIFIED BY '$(DB_PASSWORD)';" >> $(DB_INIT_SCRIPT)
	@for url in $(API_REPO_URLS); do \
		dir=$$(basename $$url); \
		dbname=$$(echo $$dir | sed 's/-api//g' | tr '-' '_'); \
		echo "CREATE DATABASE IF NOT EXISTS \`$$dbname\`;" >> $(DB_INIT_SCRIPT); \
		echo "GRANT ALL PRIVILEGES ON \`$$dbname\`.* TO '$(DB_USER)'@'%';" >> $(DB_INIT_SCRIPT); \
	done
	@echo "Copying init script to Docker volume..."
	@docker volume create $(DB_INIT_VOL)
	@docker container create --name temp_init -v $(DB_INIT_VOL):/init alpine > /dev/null
	@docker cp $(DB_INIT_SCRIPT) temp_init:/init/01-init.sql
	@docker rm temp_init > /dev/null

clean:
	$(DOCKER_COMPOSE) down -v
	rm -f $(DB_INIT_SCRIPT)

clean-full: clean
	rm -rf $(SERVICES) $(DB_INIT_SCRIPT) mysql-init
